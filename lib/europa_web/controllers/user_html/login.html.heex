<.header>{gettext("Login")}</.header>

<Layouts.flash_group flash={@flash} />

<.form :let={f} for={@changeset} id="register-form" action={~p"/users/login"}>
  <.input type="text" field={f[:username]} label={"#{gettext("Username")}"} />
  <.input type="password" field={f[:password]} label={"#{gettext("Password")}"} />

  <.button>{gettext("Login")}</.button>
</.form>
