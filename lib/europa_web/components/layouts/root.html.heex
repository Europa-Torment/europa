<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Europa">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body>
    <div class="navbar bg-base-100 shadow-sm font-mono">
      <div class="flex-1">
        <a class="btn btn-ghost text-xl">Europa Torment</a>
      </div>
      <div class="flex-none">
        <ul class="menu menu-horizontal px-1">
          <%= if assigns[:current_user] do %>
            <li><.link navigate={~p"/games"}>{gettext("Games")}</.link></li>
            <li><.link navigate={~p"/users/logout"}>{gettext("Sign out")}</.link></li>
          <% else %>
            <li><.link navigate={~p"/users/register"}>{gettext("Sign up")}</.link></li>
            <li><.link navigate={~p"/users/login"}>{gettext("Sign in")}</.link></li>
          <% end %>
        </ul>
      </div>
    </div>
    <div class="container mx-auto py-8 font-mono">
      {@inner_content}
    </div>
  </body>
</html>
