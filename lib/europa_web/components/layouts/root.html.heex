<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default={gettext("Europa Torment - browser game")}>
      {assigns[:page_title]}
    </.live_title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,600;14..32,800&family=Orbitron:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class={if assigns[:game_page], do: "h-screen overflow-hidden", else: ""}>
    <div class="navbar bg-base-200 shadow-sm">
      <div class="flex-1">
        <.link navigate="/" class="btn btn-ghost text-xl font-display font-bold text-cyan-300 tracking-wide">
          Europa Torment
        </.link>
      </div>
      <div class="flex-none">
        <ul class="menu menu-horizontal px-1">
          <%= if assigns[:current_user] do %>
            <li><.link navigate={~p"/games"}>🎮 {gettext("Games")}</.link></li>
            <li><.link navigate={~p"/lore"}>📚 {gettext("Lore")}</.link></li>
            <li><.link navigate={~p"/games/leaderboard"}>🏆 {gettext("Leaderboard")}</.link></li>
            <li>
              <details class="dropdown dropdown-end">
                <summary class="font-bold text-primary">
                  {@current_user_username}
                </summary>
                <ul class="menu dropdown-content bg-base-200 rounded-box z-[1] w-48 p-2 shadow">
                  <li>
                    <.link navigate={~p"/users/logout"} class="whitespace-nowrap">
                      {gettext("Sign out")}
                    </.link>
                  </li>
                </ul>
              </details>
            </li>
          <% else %>
            <li>
              <.button class="btn btn-outline btn-info btn-sm mr-2" navigate={~p"/users/register"}>
                {gettext("Sign up")}
              </.button>
            </li>
            <li>
              <.button class="btn btn-outline btn-secondary btn-sm" navigate={~p"/users/login"}>
                {gettext("Sign in")}
              </.button>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
    <div class="container mx-auto py-8 font-mono">
      {@inner_content}
    </div>
  </body>
</html>
